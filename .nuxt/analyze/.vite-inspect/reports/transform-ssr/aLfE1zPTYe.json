        "sourcesContent": [
          "<template>\r\n  <section\r\n    class=\"sign gradient-form\"\r\n    :class=\"$i18n.locale === 'ar' ? 'bodyAR' : ''\"\r\n  >\r\n    <div class=\"container\">\r\n      <div class=\"row d-flex justify-content-center align-items-center h-100\">\r\n        <div class=\"col-xl-10\">\r\n          <div class=\"card rounded-3 text-black\">\r\n            <div class=\"row g-0\">\r\n              <div class=\"col-lg-6\">\r\n                <div class=\"card-body p-md-5 mx-md-4\">\r\n                  <div class=\"text-center\">\r\n                    <div class=\"d-flex mb-4 justify-content-center\">\r\n                      <img\r\n                        src=\"/photos/g.png\"\r\n                        alt=\"\"\r\n                        class=\"logo\"\r\n                        loading=\"lazy\"\r\n                      />\r\n                      <div class=\"d-flex flex-column\">\r\n                        <!-- <img style=\"width: 50px; height: 50px\" src=\"../assets/bdgOne.png\" alt=\"\" />\r\n                          <img style=\"width: 50px; height: 50px\" src=\"../assets/bdgTwo.png\" alt=\"\" /> -->\r\n                      </div>\r\n                    </div>\r\n\r\n                    <h4 class=\"title mt-1 mb-5 pb-1\">\r\n                      {{\r\n                        $i18n.locale === \"ar\"\r\n                          ? \"نحن فريق نبتتي 🌱\"\r\n                          : \"We are The Nabtaty Team 🌱\"\r\n                      }}\r\n                    </h4>\r\n                  </div>\r\n\r\n                  <form @submit.prevent=\"login()\">\r\n                    <div class=\"d-flex flex-column-reverse mb-3\">\r\n                      <input\r\n                        v-model=\"username\"\r\n                        id=\"username\"\r\n                        type=\"text\"\r\n                        required\r\n                        maxlength=\"30\"\r\n                        :placeholder=\"\r\n                          $i18n.locale === 'ar'\r\n                            ? 'اكتب اسم المستخدم الخاص بك'\r\n                            : 'Type your username'\r\n                        \"\r\n                      />\r\n                      <label for=\"username\">{{\r\n                        $i18n.locale == \"ar\" ? \"اسم المستخدم\" : \"Username\"\r\n                      }}</label>\r\n                    </div>\r\n\r\n                    <div class=\"d-flex flex-column-reverse mb-3\">\r\n                      <input\r\n                        v-model=\"password\"\r\n                        id=\"password\"\r\n                        type=\"password\"\r\n                        required\r\n                        maxlength=\"30\"\r\n                        :placeholder=\"\r\n                          $i18n.locale === 'ar'\r\n                            ? 'اكتب كلمة المرور الخاصة بك'\r\n                            : 'Type your password'\r\n                        \"\r\n                        minlength=\"6\"\r\n                      />\r\n                      <label for=\"username\"\r\n                        >{{ $i18n.locale === \"ar\" ? \"كلمة السر\" : \"Password\" }}\r\n                      </label>\r\n                    </div>\r\n\r\n                    <!-- Submit button -->\r\n                    <div class=\"text-center pt-1 mb-1 pb-1\">\r\n                      <div class=\"login\">\r\n                        <input\r\n                          type=\"submit\"\r\n                          class=\"basic\"\r\n                          :value=\"\r\n                            $i18n.locale === 'ar' ? 'تسجيل الدخول' : 'Log In'\r\n                          \"\r\n                        />\r\n                      </div>\r\n                    </div>\r\n                  </form>\r\n                </div>\r\n              </div>\r\n              <div\r\n                class=\"text-box col-lg-6 d-flex align-items-center gradient-custom-2\"\r\n              >\r\n                <div class=\"text-white box px-3 py-4 p-md-5 mx-md-4\">\r\n                  <img src=\"/photos/tabLogo.png\" alt=\"\" loading=\"lazy\" />\r\n                  <h4 class=\"mb-4\">\r\n                    {{\r\n                      $i18n.locale === \"ar\"\r\n                        ? \"نحن أكثر من مجرد متجر!\"\r\n                        : \"We’re more than just a store!\"\r\n                    }}\r\n                  </h4>\r\n\r\n                  <p class=\"small mb-0\">\r\n                    {{\r\n                      $i18n.locale === \"ar\"\r\n                        ? \"انضم إلينا في العالم الساحر للتسوق عبر الإنترنت واكتشف طريقة جديدة للعثور على الخضروات المفضلة لديك. مرحبًا بكم في نبتي، حيث تجتمع الراحة مع متعة رعاية الطبيعة! زراعة سعيدة!\"\r\n                        : \"Join us in the enchanting world of online plant shopping and uncover a fresh approach to finding your favorite greens. Welcome to Nabtty, where convenience meets the joy of nurturing nature! Happy planting!\"\r\n                    }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n</template>\r\n\r\n<script setup>\r\ndefinePageMeta({\r\n  layout: false, // This will disable the default layout\r\n});\r\nconst username = ref(\"\");\r\nconst password = ref(\"\");\r\nconst login = () => {\r\n  useAuth().value.isAuthenticated = true;\r\n  localStorage.setItem(\"token\", \"test token\");\r\n  navigateTo(\"/\");\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.sign {\r\n  background-color: #eee;\r\n  min-height: 100vh;\r\n  display: flex;\r\n  align-items: center;\r\n  .title {\r\n    color: #003d29;\r\n  }\r\n  .logo {\r\n    width: 350px;\r\n    height: 150px;\r\n    object-fit: contain;\r\n    @media (max-width: 425px) {\r\n      width: 225px;\r\n      height: 90px;\r\n    }\r\n  }\r\n  .login {\r\n    input {\r\n      width: 100%;\r\n      padding: 5px;\r\n      border-radius: 3px;\r\n      border: none;\r\n      background-color: #003d29;\r\n      color: #fff;\r\n    }\r\n  }\r\n  .text-box {\r\n    position: relative;\r\n    display: block;\r\n    background-color: #003d29;\r\n    border-top-right-radius: 8px;\r\n    border-bottom-right-radius: 8px;\r\n    overflow: hidden;\r\n    @media (max-width: 991px) {\r\n      display: none !important;\r\n    }\r\n    img {\r\n      position: absolute;\r\n      top: 50%;\r\n      left: 50%;\r\n      transform: translate(-50%, -50%);\r\n      width: 80%;\r\n      opacity: 0.3;\r\n      mix-blend-mode: multiply;\r\n    }\r\n    h4,\r\n    p {\r\n      position: relative;\r\n      z-index: 4;\r\n    }\r\n  }\r\n}\r\n.box {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  flex-direction: column;\r\n  text-align: center;\r\n}\r\n\r\ninput,\r\ntextarea {\r\n  color: #000;\r\n}\r\n</style>\r\n"
        ]
